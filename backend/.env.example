# ERP-IOT Backend Environment Variables
# Copy this file to .env and fill in real values before running.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/erp_iot

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# JWT expiry in minutes (default 480 = 8 hours)
JWT_EXPIRE_MINUTES=480

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Seeding ───────────────────────────────────────────────────────────────────
# First-run seed: creates a super_admin user with these credentials.
DEFAULT_ADMIN_EMAIL=admin@erp-iot.local
DEFAULT_ADMIN_PASSWORD=change-me-in-production

# ── Pedestal API ──────────────────────────────────────────────────────────────
# Default timeouts/retries (override per-marina in DB)
PEDESTAL_API_TIMEOUT_SECONDS=10
PEDESTAL_API_MAX_RETRIES=3

# ── Service account password encryption ──────────────────────────────────────
# Fernet symmetric key for encrypting service account passwords at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: if you change this key, all stored passwords become unreadable.
ERP_ENCRYPTION_KEY=change-me-generate-with-fernet
